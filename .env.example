WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=
APP_SIGNING_SECRET=

# Optional local server settings
HOST=127.0.0.1
PORT=8000
APP_URL=http://127.0.0.1:8000
COOKIE_SECURE=false

# Revoke WorkOS sessions after this absolute age. Default: 7 days.
SESSION_MAX_AGE_SECONDS=604800
# SESSION_METADATA_COOKIE_NAME=zamp_session_meta
# OTP_EMAIL_COOKIE_NAME=zamp_otp_email
# EMAIL_VERIFICATION_COOKIE_NAME=zamp_email_verification
# CSRF_COOKIE_NAME=zamp_csrf

# Mail ingestion / PostgreSQL
DATABASE_URL=postgresql://zamp:password@127.0.0.1:5432/zamp
MAIL_DB_POOL_MIN_SIZE=1
MAIL_DB_POOL_MAX_SIZE=10
MAIL_TOKEN_ENCRYPTION_KEY=
MAIL_PDF_STORAGE_DIR=./storage/mail_pdfs
MAIL_FRONTEND_REDIRECT_URL=http://127.0.0.1:8000/dashboard
MAIL_PARSE_OCR_MAX_REGIONS=8

# Gmail OAuth + Pub/Sub push
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-inbound
GMAIL_PUBSUB_SUBSCRIPTION=projects/your-project/subscriptions/gmail-inbound-push
# Configure the Pub/Sub push subscription to mint an OIDC token for this audience.
GMAIL_PUBSUB_OIDC_AUDIENCE=http://127.0.0.1:8000/webhooks/gmail/pubsub
GMAIL_PUBSUB_OIDC_SERVICE_ACCOUNT_EMAIL=
# Optional fallback for local setups. Send only as X-Zamp-Webhook-Secret.
GMAIL_WEBHOOK_SECRET=

# Microsoft Outlook OAuth + Graph webhooks
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
